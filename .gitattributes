# Auto detect text files and perform LF normalization
* text=auto

# Standardize line endings to LF for scripts and code
*.py text eol=lf
*.rs text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.webm binary
